{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(Mobile|iPhone|iPad|Android|webOS|BlackBerry|Opera Mini|IEMobile).*"
        }
      ],
      "destination": "/mobile",
      "permanent": false
    }
  ]
}
