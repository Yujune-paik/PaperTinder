OPENAI_API_KEY=sk-your-api-key-here

# Google OAuth (optional but required for user-specific settings)
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# Admin role: comma-separated emails. Login from any of these auto-grants
# admin access to /api/admin/* and the /admin page.
ADMIN_EMAILS=

# CORS: comma-separated origins for production. Leave blank for "*" (dev only).
ALLOWED_ORIGINS=

# Rate limits (per-day). 0 means unlimited.
RATE_LIMIT_ANON_PER_DAY=20
RATE_LIMIT_USER_PER_DAY=100
SUMMARY_INFLIGHT_TTL=120

# Vercel deployment only (leave blank for local development)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
BLOB_READ_WRITE_TOKEN=

# Scrapbox export (optional)
# SID: ブラウザの Cookie から connect.sid の値をコピー
# PROJECT: Scrapbox プロジェクト名 (URLの scrapbox.io/PROJECT の部分)
SCRAPBOX_SID=
SCRAPBOX_PROJECT=

# NotebookLM export (optional, uses notebooklm-py)
# ローカル: `notebooklm login` で自動認証（ブラウザが開く）
# Vercel/CI: ~/.notebooklm/profiles/default/storage_state.json の中身を設定
NOTEBOOKLM_AUTH_JSON=
